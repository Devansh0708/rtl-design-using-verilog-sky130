# ==========================================
# RTL Design using Verilog - .gitignore
# ==========================================

# ----------------------------
# Simulation Outputs
# ----------------------------
*.vcd
*.vvp
*.fst
*.lxt
*.out
*.log

# ----------------------------
# GTKWave
# ----------------------------
*.gtkw

# ----------------------------
# Yosys Generated Files
# ----------------------------
*.dot
*.ilang
*.json

# ----------------------------
# Temporary Files
# ----------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ----------------------------
# Operating System Files
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------
# Python Cache (for future automation)
# ----------------------------
__pycache__/
*.pyc

# ----------------------------
# Archives
# ----------------------------
*.zip
*.tar
*.tar.gz

# ----------------------------
# VS Code Settings
# ----------------------------
.vscode/settings.json

# ----------------------------
# Keep Documentation
# ----------------------------
!docs/
!notes/
!screenshots/